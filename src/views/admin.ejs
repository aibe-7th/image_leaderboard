<!DOCTYPE html>
<html lang="ko">
<head>
    <title>Challenge Admin - Leaderboard</title>
    <%- include('partials/head') %>
    <style>
        .admin-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 2.5rem;
            margin-top: 2rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body class="bg-dark text-light">
    <%- include('partials/nav') %>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <h1 class="text-center text-info mb-4 fw-bold">⚙️ Challenge Admin</h1>
                
                <!-- Login Section -->
                <form id="loginForm" class="admin-card fade-in">
                    <h3 class="h5 mb-4 text-center text-secondary">관리자 인증이 필요합니다</h3>
                    <div class="mb-3">
                        <label class="form-label">관리자 비밀번호</label>
                        <input type="password" id="adminPass" class="form-control" placeholder="비밀번호를 입력하세요" required>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-info text-white fw-bold py-2">로그인</button>
                    </div>
                </form>

                <!-- Admin Section (Initially Hidden) -->
                <div id="adminSection" class="admin-card fade-in hidden">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="h5 mb-0 text-info">✨ 챌린지 등록</h3>
                        <button id="logoutBtn" class="btn btn-outline-secondary btn-sm">로그아웃</button>
                    </div>

                    <form id="challengeForm">
                        <div class="mb-3">
                            <label class="form-label">정답 프롬프트</label>
                            <textarea id="prompt" class="form-control" rows="2" placeholder="정답 프롬프트를 입력하세요" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">정답 이미지</label>
                            <input type="file" id="image_file" class="form-control" accept="image/*" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">시작일</label>
                                <input type="date" id="start_date" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">종료일</label>
                                <input type="date" id="end_date" class="form-control" required>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label">노출 여부</label>
                            <select id="show_yn" class="form-select">
                                <option value="Y">노출 (Y)</option>
                                <option value="N">숨김 (N)</option>
                            </select>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-info text-white fw-bold py-2 shadow-sm">챌린지 등록하기</button>
                        </div>
                    </form>
                </div>
                
                <div id="status" class="mt-4 text-center"></div>

                <div class="text-center mt-5">
                    <a href="/" class="text-secondary text-decoration-none opacity-50 hover-opacity-100">← 메인 리더보드로 돌아가기</a>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script>
        const loginForm = document.getElementById('loginForm');
        const adminSection = document.getElementById('adminSection');
        const logoutBtn = document.getElementById('logoutBtn');
        const challengeForm = document.getElementById('challengeForm');
        const statusDiv = document.getElementById('status');

        function checkSession() {
            const token = sessionStorage.getItem('adminToken');
            if (token) {
                loginForm.classList.add('hidden');
                adminSection.classList.remove('hidden');
            } else {
                loginForm.classList.remove('hidden');
                adminSection.classList.add('hidden');
            }
        }

        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const password = document.getElementById('adminPass').value;
            
            try {
                const response = await axios.post('/api/admin/login', { password }, {
                    headers: { 'Content-Type': 'application/json' }
                });
                sessionStorage.setItem('adminToken', response.data.token);
                checkSession();
                statusDiv.textContent = '';
                document.getElementById('adminPass').value = '';
            } catch (error) {
                console.error('Login Error:', error);
                alert('로그인 실패: ' + (error.response?.data?.error || '비밀번호를 확인하세요.'));
            }
        });

        logoutBtn.addEventListener('click', () => {
            sessionStorage.removeItem('adminToken');
            checkSession();
            statusDiv.textContent = '';
        });

        challengeForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const token = sessionStorage.getItem('adminToken');
            if (!token) return checkSession();

            const formData = new FormData();
            formData.append('prompt', document.getElementById('prompt').value);
            formData.append('image_file', document.getElementById('image_file').files[0]);
            formData.append('start_date', document.getElementById('start_date').value);
            formData.append('end_date', document.getElementById('end_date').value);
            formData.append('show_yn', document.getElementById('show_yn').value);

            statusDiv.className = 'mt-3 text-info';
            statusDiv.textContent = '처리 중...';

            try {
                await axios.post('/api/admin/challenge', formData, {
                    headers: {
                        'Admin-Session': token,
                        'Content-Type': 'multipart/form-data'
                    }
                });
                statusDiv.className = 'mt-3 text-success fw-bold';
                statusDiv.textContent = '✅ 챌린지가 성공적으로 등록되었습니다!';
                challengeForm.reset();
            } catch (error) {
                console.error(error);
                statusDiv.className = 'mt-3 text-danger';
                statusDiv.textContent = '❌ 실패: ' + (error.response?.data?.error || '처리 중 오류 발생');
                if (error.response?.status === 401) {
                    sessionStorage.removeItem('adminToken');
                    checkSession();
                }
            }
        });

        checkSession();
    </script>
</body>
</html>
