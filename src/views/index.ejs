<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Image Challenge - Arena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .challenge-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            overflow: hidden;
            transition: transform 0.3s ease;
        }
        .challenge-card:hover { transform: translateY(-5px); }
        .leaderboard-table { font-size: 0.9rem; }
        .leaderboard-table th { background: rgba(255, 255, 255, 0.1) !important; }
        .arena-notice {
            background: linear-gradient(135deg, rgba(13, 202, 240, 0.1) 0%, rgba(13, 110, 253, 0.1) 100%);
            border: 1px solid rgba(13, 202, 240, 0.2);
        }
    </style>
</head>
<body class="bg-dark text-light">
    <nav class="navbar navbar-dark bg-black py-3 shadow-sm">
        <div class="container d-flex justify-content-between">
            <a class="navbar-brand fw-bold text-info fs-4" href="/">AI IMAGE ARENA</a>
            <a href="/admin" class="btn btn-outline-secondary btn-sm opacity-50">Admin</a>
        </div>
    </nav>

    <div class="container py-5">
        <!-- Arena Notice -->
        <div class="arena-notice p-4 rounded-4 text-center mb-5 fade-in">
            <h2 class="h5 fw-bold text-info mb-2">🎨 나만의 이미지를 만들고 도전해보세요!</h2>
            <p class="mb-0 text-secondary small">
                아래 리스트 중 도전하고 싶은 챌린지를 선택하세요. <br>
                이미지 생성이 필요하다면 <a href="https://arena.ai" target="_blank" class="text-info text-decoration-underline fw-bold">arena.ai</a>를 이용해보세요.
            </p>
        </div>

        <!-- Submission Scroll Button -->
        <div class="text-center mb-5">
            <button class="btn btn-info btn-lg text-white fw-bold px-5 shadow" onclick="window.scrollToSubmit()">지금 바로 도전하기</button>
        </div>

        <!-- Challenge List (SSR) -->
        <div id="challengeList" class="row g-5">
            <% if (challenges && challenges.length > 0) { %>
                <% challenges.forEach(challenge => { %>
                    <div class="col-12 mb-5 fade-in">
                        <div class="challenge-card">
                            <div class="row g-0">
                                <div class="col-lg-5 bg-black d-flex align-items-center justify-content-center border-end border-secondary border-opacity-25 p-3">
                                    <img src="/api/image/<%= challenge.result_image %>" class="img-fluid rounded-3 shadow" style="max-height: 400px;" alt="Challenge Image">
                                </div>
                                <div class="col-lg-7 p-4 p-md-5">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h3 class="h4 text-info fw-bold mb-0">챌린지 #<%= challenge.id %></h3>
                                        <span class="badge bg-info text-white">진행 중</span>
                                    </div>
                                    <p class="text-secondary mb-4">이미지를 보고 가장 유사한 프롬프트를 맞춰보세요. (기간: <%= challenge.start_date %> ~ <%= challenge.end_date %>)</p>
                                    
                                    <div class="table-responsive">
                                        <table class="table table-dark table-hover align-middle leaderboard-table border-secondary border-opacity-25">
                                            <thead>
                                                <tr class="text-secondary small">
                                                    <th>순위</th>
                                                    <th>이름</th>
                                                    <th>유사도</th>
                                                    <th>일자</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (challenge.leaderboard && challenge.leaderboard.length > 0) { %>
                                                    <% challenge.leaderboard.slice(0, 10).forEach((r, i) => { %>
                                                        <tr>
                                                            <td class="fw-bold text-warning"><%= i + 1 %></td>
                                                            <td>
                                                                <span class="d-block text-white"><%= r.name %></span>
                                                                <small class="text-secondary" style="font-size: 0.7rem;"><%= r.ip || "-" %></small>
                                                            </td>
                                                            <td class="text-info fw-bold"><%= r.prompt_score %></td>
                                                            <td class="text-secondary" style="font-size: 0.75rem;"><%= new Date(r.created_at).toLocaleDateString() %></td>
                                                        </tr>
                                                    <% }) %>
                                                <% } else { %>
                                                    <tr><td colspan="4" class="text-center py-3 text-secondary small">첫 번째로 도전해보세요!</td></tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5 text-secondary">현재 진행 중인 챌린지가 없습니다.</div>
            <% } %>
        </div>
    </div>

    <!-- Submission Section Footer -->
    <div id="submitAnchor" class="container pb-5">
        <hr class="opacity-10 my-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card bg-black border-info border-opacity-25 rounded-4 p-4 shadow-lg">
                    <h2 class="h4 text-info text-center mb-4 fw-bold">챌린지 참여하기</h2>
                    <form id="submitForm">
                        <div class="mb-3">
                            <label class="form-label text-secondary small">도전할 챌린지</label>
                            <select id="challenge_id" class="form-select bg-dark text-white border-secondary" required>
                                <option value="">챌린지를 선택하세요</option>
                                <% challenges.forEach(c => { %>
                                    <option value="<%= c.id %>"><%= c.prompt.substring(0, 20) %>...</option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-secondary small">이름</label>
                            <input id="name" type="text" class="form-control bg-dark text-white border-secondary" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-secondary small">나의 결과 이미지</label>
                            <input id="image_file" type="file" accept="image/*" class="form-control bg-dark text-white border-secondary" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-secondary small">프롬프트 (10-100자)</label>
                            <textarea id="prompt" class="form-control bg-dark text-white border-secondary" rows="3" minlength="10" maxlength="100" required></textarea>
                        </div>
                        <button type="submit" id="submitBtn" class="btn btn-info btn-lg w-100 text-white fw-bold">유사도 검증 및 제출</button>
                        <div id="status" class="mt-3 text-center small"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/script/form.js"></script>
    <script>
        window.scrollToSubmit = () => {
            document.getElementById('submitAnchor').scrollIntoView({ behavior: 'smooth' });
        };
    </script>
</body>
</html>
