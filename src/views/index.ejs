<!DOCTYPE html>
<html lang="ko">

<head>
    <%- include('partials/head') %>
        <style>
            .challenge-item {
                cursor: pointer;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .challenge-item:hover {
                transform: scale(1.02);
                box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
            }

            .challenge-overlay {
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                background: linear-gradient(transparent, rgba(0, 0, 0, 0.9));
                padding: 2rem;
                opacity: 0.9;
            }
        </style>
</head>

<body class="bg-dark text-light">
    <%- include('partials/nav') %>

        <div class="container py-5">
            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-info mb-3">🔥 이미지 프롬프트를 맞춰라</h1>
                <p class="text-secondary lead">이미지 속 숨겨진 프롬프트를 맞추고 고득점에 도전하세요!</p>
            </div>

            <!-- Challenge List -->
            <div class="row g-4 justify-content-center">
                <% if (challenges && challenges.length> 0) { %>
                    <% challenges.forEach(c=> { %>
                        <div class="col-12 col-lg-10 col-xl-9 mb-3">
                            <div class="challenge-card challenge-item overflow-hidden shadow-lg border border-secondary border-opacity-10"
                                onclick="location.href='/challenge/<%= c.id %>'">
                                <div class="row g-0">
                                    <div class="col-md-5 col-lg-4">
                                        <div class="position-relative h-100">
                                            <img src="/api/image/<%= c.result_image %>" class="img-fluid h-100"
                                                style="min-height: 220px; object-fit: cover;" alt="Challenge">
                                        </div>
                                    </div>
                                    <div class="col-md-7 col-lg-8 p-4 d-flex flex-column justify-content-center">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h3 class="h4 fw-bold text-white mb-0">Challenge #<%= c.id %>
                                            </h3>
                                            <% const count=participantCounts[c.id] || 0; %>
                                                <span
                                                    class="badge rounded-pill bg-info text-white border border-info border-opacity-50 px-3 py-2 shadow-sm">
                                                    <% if (count===0) { %>
                                                        🔥 첫 번째 주인공이 되어보세요!
                                                        <% } else { %>
                                                            🔥 <%= count %>명 도전 중
                                                                <% } %>
                                                </span>
                                        </div>
                                        <div class="mt-auto d-flex align-items-center justify-content-between">
                                            <div class="text-secondary small">
                                                <i class="bi bi-calendar3 me-1"></i>
                                                <%= c.start_date %> ~ <%= c.end_date %>
                                            </div>
                                            <span class="btn btn-info text-white fw-bold px-4 shadow-sm">도전하기</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="col-12 text-center py-5">
                                    <p class="text-secondary">현재 진행 중인 챌린지가 없습니다.</p>
                                </div>
                                <% } %>
            </div>
        </div>

        <%- include('partials/footer') %>
</body>

</html>