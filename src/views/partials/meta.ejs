<!-- Favicon -->
<link rel="icon" type="image/png" href="/favicon.png">
<link rel="apple-touch-icon" href="/favicon.png">

<!-- Primary Meta Tags -->
<meta name="title" content="이미지 프롬프트를 맞춰라">
<meta name="description" content="AI가 생성한 이미지를 보고 원본 프롬프트를 맞춰보세요. 고득점을 노려보세요!">

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website">
<meta property="og:url" content="<%= baseUrl %>">
<meta property="og:title" content="이미지 프롬프트를 맞춰라 - Arena">
<meta property="og:description" content="AI가 생성한 이미지를 보고 원본 프롬프트를 맞춰보세요. 고득점을 획득하고 리더보드에 이름을 올리세요!">
<meta property="og:image" content="<%= baseUrl %>/og-image.png">

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image">
<meta property="twitter:url" content="<%= baseUrl %>">
<meta property="twitter:title" content="이미지 프롬프트를 맞춰라 - Arena">
<meta property="twitter:description" content="AI가 생성한 이미지를 보고 원본 프롬프트를 맞춰보세요. 고득점을 획득하고 리더보드에 이름을 올리세요!">
<meta property="twitter:image" content="<%= baseUrl %>/og-image.png">